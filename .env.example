COCOMPUTE_PORT=4000
COCOMPUTE_DB_PATH=./cocompute.db
COCOMPUTE_STATIC_DIR=orchestrator/static
COCOMPUTE_BASE_URL=http://localhost:4000
COCOMPUTE_SESSION_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# Both required to enable captcha on /beta. If either is unset, captcha is skipped (dev mode).
# Site key is public (rendered in HTML). Secret key is server-only — keep this file gitignored.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
